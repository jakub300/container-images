{
  "name": "msb-rails-devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "options": [
      "--build-context",
      "shared=${localWorkspaceFolder}/../shared"
    ]
  },
  "features": {
    "ghcr.io/rails/devcontainer/features/activestorage:1": {
      "variantProcessor": "mini_magick"
    },
    "ghcr.io/rails/devcontainer/features/postgres-client:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "./shared-features/gitlab-cli": {},
    "./shared-features/zx": {}
  },
  "workspaceFolder": "/workspaces"
}
